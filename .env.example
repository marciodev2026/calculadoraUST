# Copie para .env e ajuste os valores antes do deploy
# cp .env.example .env

# Porta pública do Nginx
APP_PORT=80

# Banco de dados
DB_NAME=ust_calculator
DB_USER=ust_user
DB_PASSWORD=ust_pass

# JWT — altere em produção (mínimo 256 bits)
JWT_SECRET=ust-gov-calculator-jwt-secret-key-min-256-bits-required-for-hs256-algorithm

# SMTP Mailpit (opcional — rode scripts/start-mailpit.ps1)
# MAIL_HOST=localhost
# MAIL_PORT=1025
# MAILPIT_UI_URL=http://localhost:8025
# REPORTS_STORAGE_PATH=/app/storage/relatorios
# BRANDING_STORAGE_PATH=/app/storage/branding
